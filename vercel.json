{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "src/server.js"
    },
    "ai-service": {
      "root": "ai-service",
      "entrypoint": "app.py"
    }
  },
  "rewrites": [
    {
      "source": "/ai(/.*)?",
      "destination": {
        "type": "service",
        "service": "ai-service"
      }
    },
    {
      "source": "/api(/.*)?",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/((?!api|ai|assets|vite.svg|uploads|logo.png|favicon.ico).*)",
      "destination": {
        "type": "service",
        "service": "frontend",
        "path": "/index.html"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
