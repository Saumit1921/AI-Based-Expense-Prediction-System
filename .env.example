# App Configuration
NODE_ENV=development
PORT=5000

# Database
# If using PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# If using SQLite fallback: file:./dev.db
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/expense_tracker?schema=public"

# JWT Authentication secret
JWT_SECRET=super_secret_jwt_token_key_123456

# AI Service Configuration
AI_SERVICE_URL=http://127.0.0.1:8000
